      "src": "https://inside-docupedia.bosch.com/confluence/download/attachments/embedded-page/CARSFW/1.0%20VCU%20Plus%20-%20SUSD%20with%20EcuModeManager/image-2024-8-12_13-53-30.png?api=v2",
