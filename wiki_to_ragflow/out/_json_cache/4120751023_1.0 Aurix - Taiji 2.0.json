    {
      "type": "heading",
      "level": 1,
      "text": "Overview"
    },
    {
      "type": "paragraph",
      "text": "This page summarizes How we will go with Taiji Platform to support more requirements and projects related to COEMs."
    },
    {
      "type": "heading",
      "level": 1,
      "text": "Current Taiji Platform"
    },
    {
      "type": "paragraph",
      "text": "Current Taiji Platform supports only Vector solution"
    },
    {
      "type": "image",
      "src": "https://inside-docupedia.bosch.com/confluence/download/attachments/embedded-page/CARSFW/1.0%20Aurix%20-%20Taiji%202.0/image-2024-4-12_17-12-17.png?api=v2",
      "alt": "",
