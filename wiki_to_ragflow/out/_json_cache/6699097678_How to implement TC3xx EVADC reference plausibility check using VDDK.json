      "src": "https://inside-docupedia.bosch.com/confluence/download/attachments/embedded-page/CARSFW/How%20to%20implement%20TC3xx%20EVADC%20reference%20plausibility%20check%20using%20VDDK/image-2026-1-16_10-10-40.png?api=v2",
      "alt": "",
