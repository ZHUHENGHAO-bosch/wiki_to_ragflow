      "type": "heading",
      "level": 1,
      "text": "Overview"
    },
    {
      "type": "paragraph",
      "text": "This page summarizes the OS measurement done in SAIL El SW to check OS task timings"
    },
    {
      "type": "heading",
      "level": 1,
      "text": "OS task measurement"
    },
    {
      "type": "paragraph",
      "text": "We used SAIL_ERR1 pin to toggle the waveform to get the OS task timings"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "Core 0 - 10ms"
    },
    {
      "type": "paragraph",
      "text": "Average timing was 9.85 ms"
