    {
      "type": "heading",
      "level": 1,
      "text": "1. Relationship with other SWC"
    },
    {
      "type": "image",
      "src": "https://inside-docupedia.bosch.com/confluence/download/attachments/embedded-page/CARSFW/SWC_INFO_CDD_VipIncRouter_SRC/image-2024-8-27_15-55-33.png?api=v2",
