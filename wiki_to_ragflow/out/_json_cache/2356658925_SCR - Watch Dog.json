    },
    {
      "type": "heading",
      "level": 2,
      "text": "SCR WDT Block Diagram"
    },
    {
      "type": "image",
      "src": "https://inside-docupedia.bosch.com/confluence/download/attachments/embedded-page/CARSFW/SCR%20-%20Watch%20Dog/image2022-8-5_12-7-37.png?api=v2",
      "alt": "",
