    {
      "type": "paragraph",
      "text": "MCAL support for this alternate"
    },
    {
      "type": "image",
      "src": "https://inside-docupedia.bosch.com/confluence/download/attachments/embedded-page/CARSFW/VAREF%20plausibility/image2022-10-19_11-13-46.png?api=v2",
