    },
    {
      "type": "heading",
      "level": 2,
      "text": "2.2. Protocol Configuration"
    },
    {
      "type": "image",
      "src": "https://inside-docupedia.bosch.com/confluence/download/attachments/embedded-page/CARSFW/How%20to%20configure%20I2C/image-2024-11-3_18-33-52.png?api=v2",
      "alt": "",
      "local_path": "_images/How to configure I2C/image-2024-11-3_18-33-52.png"
    },
    {
      "type": "paragraph",
      "text": "I2C Access Mode: I2C_POLLING_MODE/I2C_DMA_MODE/I2C_FIFO_MODE"
    },
    {
      "type": "paragraph",
      "text": "I2c Hw Channel Id: select SE0"
    },
    {
      "type": "paragraph",
      "text": "SAIL_PMIC I2C Add: 0x28"
    },
    {
