  "content": [
    {
      "type": "heading",
      "level": 1,
      "text": "Step1: Build your software."
    },
    {
      "type": "heading",
      "level": 1,
      "text": "Step2: Generate QAC project."
    },
    {
      "type": "paragraph",
      "text": "Move to path: \\Config\\Autosar\\Build\\HelixQAC\\Tool.PRQA."
    },
    {
      "type": "paragraph",
      "text": "Run command: .\\GenerateQAC.bat --CX1E"
    },
    {
      "type": "paragraph",
      "text": "QAC project will be generated in path: \\Config\\Autosar\\Build\\PRQA_CX1E"
    },
    {
      "type": "heading",
      "level": 1,
      "text": "Step3: Open QAC"
    },
    {
      "type": "paragraph",
      "text": "Move to path: \\Config\\Autosar\\Build\\PRQA_CX1E"
    },
    {
      "type": "paragraph",
      "text": "double click on: OpenProjectInGUI.bat"
    },
    {
      "type": "heading",
      "level": 1,
      "text": "Step4: Choose file to Analysis"
    },
    {
      "type": "paragraph",
      "text": "Select file or folder;"
    },
    {
      "type": "paragraph",
      "text": "Right click and choose Analyze Selected File(s)."
    },
    {
      "type": "image",
      "src": "https://inside-docupedia.bosch.com/confluence/download/attachments/embedded-page/CARSFW/How%20to%20Use%20QAC%20for%20Single%20File%20Analysys/image-2023-8-9_15-49-25.png?api=v2",
      "alt": "",
      "local_path": "_images/How to Use QAC for Single File Analysys/image-2023-8-9_15-49-25.png"
    },
    {
      "type": "heading",
      "level": 1,
      "text": "Step5: Check the Warnings and Fix"
    },
    {
      "type": "paragraph",
      "text": "Warnings will be shown in the bottom of the QAC tool."
    },
    {
      "type": "paragraph",
      "text": "Click on the ID and check the help manual to fix the issue."
    },
    {
      "type": "image",
      "src": "https://inside-docupedia.bosch.com/confluence/download/attachments/embedded-page/CARSFW/How%20to%20Use%20QAC%20for%20Single%20File%20Analysys/image-2023-8-9_15-56-18.png?api=v2",
