        [
          "Parameter",
          ""
        ],
        [
          "u8ChannelNumber",
          "Channel number whose status is required"
        ],
        [
          "channelStatus",
          "channel status Bit 0: CHANNEL_OPEN_STATUS (DC for phy_err Channel) Open : 1 Close: 0 BIT 2: CHANNEL_COMM_ERROR (Only valid for phy_err Channel) Error: 1 No Error: 0 BIT 3: RX_BUFFER_THRESHOLD_EXCEEDED (not implemented) BIT 4: LINK_OK (Only valid for phy_err channel) Link Up: 1 Link DOwn: 0 BIT 5: TX_BUFFER_THRESHOLD_EXCEEDED (not implemented) BIT 6 and BIT 7 are reserved"
        ],
        [
          "Return code",
          ""
        ],
        [
          "None",
          ""
        ],
        [
          "Description",
          ""
        ],
        [
          "To get status of a channel",
          ""
        ]
