        [
          "Return code",
          ""
        ],
        [
          "(0)E_OK",
          "Data is Written successful"
        ],
        [
          "(1)E_NOT_OK",
          "Write could not be performed."
        ],
        [
          "(2)E_FLOWCONTROL_INACTIVE",
          "channel FlowControlStatus is not active"
        ],
        [
          "(3)E_BUFFULL",
          "Rbuf Full"
        ],
