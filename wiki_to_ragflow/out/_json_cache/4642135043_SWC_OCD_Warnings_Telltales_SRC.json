    {
      "type": "heading",
      "level": 2,
      "text": "3.3. Warning确认方式："
    },
    {
      "type": "table",
      "headers": [
        "",
        ""
      ],
      "rows": [
        [
          "Manual",
          "可以通过按键，手动确认消失"
        ],
        [
          "ManualAuto",
          "可以通过按键确认消失，也可以超时确认消失"
        ],
        [
          "Auto",
          "可以超时消失，但是不能手动确认消失"
        ],
        [
          "NotAck",
          "既不能手动确认，也不能超时消失"
        ]
      ]
    },
    {
