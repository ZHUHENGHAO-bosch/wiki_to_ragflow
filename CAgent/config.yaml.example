# CAgent 配置模板 — 复制为 config.yaml 后按需修改
# cp CAgent/config.yaml.example CAgent/config.yaml && vi CAgent/config.yaml

jira:
  base_url: "https://jira.example.com"
  username: ""
  api_token: ""
  project_key: "DEMO"
  verify_ssl: false

dng:
  base_url: "https://dng.example.com"
  username: ""
  password: ""
  verify_ssl: false

git_repos:
  repos: []
  search_extensions: [".c", ".h", ".py"]
  recent_commit_weeks: 4

llm:
  model: "claude-sonnet-4-20250514"
  api_key: ""
  max_tokens: 4096
  temperature: 0.0

watcher:
  mode: "webhook"
  polling_interval_seconds: 60
  jql_filter: 'issuetype = Bug AND status = Open'
  webhook_secret: ""

writer:
  analyzed_label: "analyzed"
  auto_create_related_bugs: false
  notify_webhook: ""

confluence:
  base_url: "https://confluence.example.com"
  context_path: "/confluence"
  username: ""
  api_token: ""
  auth_method: "bearer"
  verify_ssl: false
  timeout: 30.0
  max_concurrent_requests: 5
  default_output_dir: "./confluence_downloads"
  download_attachments: false
  max_depth: 5
  save_format: "pdf"
  pdf_export_method: native
  request_delay: 0.3
  max_retries: 3

ragflow:
  base_url: "http://ragflow.example.com:8880"
  api_key: ""
  dataset_name: ""
  auto_upload_after_confluence: false
  parse_after_upload: true

rtc:
  ccm_url: "https://rtc.example.com/ccm"
  username: ""
  password: ""
  verify_ssl: false
  with_jazz: true
  max_attachment_size_mb: 1024

minio:
  endpoint: "minio.example.com:9000"
  access_key: ""
  secret_key: ""
  bucket: "agent"
  prefix: "tagent"
  secure: false
